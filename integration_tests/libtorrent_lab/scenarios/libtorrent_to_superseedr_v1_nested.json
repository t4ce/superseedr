{
  "name": "libtorrent_to_superseedr_v1_nested",
  "description": "Libtorrent seeds a deterministic v1 nested-directory fixture and Superseedr downloads it over TCP.",
  "seed_client": "libtorrent",
  "leech_client": "superseedr",
  "mode": "v1",
  "torrent": "nested.torrent",
  "payload": "nested",
  "download_name": "nested",
  "timeout_secs": 180,
  "seed_listen_port": 26881,
  "leech_listen_port": 26882,
  "superseedr_peer_transport": "tcp",
  "libtorrent_settings": {
    "enable_dht": false,
    "enable_lsd": false,
    "enable_natpmp": false,
    "enable_upnp": false,
    "enable_incoming_tcp": true,
    "enable_outgoing_tcp": true,
    "enable_incoming_utp": false,
    "enable_outgoing_utp": false
  }
}
