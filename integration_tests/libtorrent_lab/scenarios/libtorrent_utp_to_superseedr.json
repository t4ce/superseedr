{
  "name": "libtorrent_utp_to_superseedr",
  "description": "A libtorrent peer seeds one deterministic v1 fixture and Superseedr downloads it with TCP disabled.",
  "seed_client": "libtorrent",
  "leech_client": "superseedr",
  "mode": "v1",
  "torrent": "single_16k.bin.torrent",
  "payload": "single/single_16k.bin",
  "download_name": "single_16k.bin",
  "timeout_secs": 180,
  "seed_listen_port": 26881,
  "leech_listen_port": 26882,
  "superseedr_peer_transport": "utp",
  "libtorrent_settings": {
    "enable_dht": false,
    "enable_lsd": false,
    "enable_natpmp": false,
    "enable_upnp": false,
    "enable_incoming_tcp": false,
    "enable_outgoing_tcp": false,
    "enable_incoming_utp": true,
    "enable_outgoing_utp": true
  }
}
